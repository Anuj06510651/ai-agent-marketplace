PORT=5001
HOST=0.0.0.0
CLIENT_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=ai_agent_marketplace

# Frontend API config
# Leave VITE_API_URL empty for local development and Vite will proxy /api to VITE_API_PROXY_TARGET.
# Set VITE_API_URL to your deployed Render backend in production.
VITE_API_URL=
VITE_API_PROXY_TARGET=http://127.0.0.1:5001

# Brain mode: rules | gemini | hybrid
BRAIN_MODE=rules

# Gemini API key (only required for gemini/hybrid)
GEMINI_API_KEY=

# Optional model override
GEMINI_MODEL=gemini-2.0-flash

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
RESET_TOKEN_TTL_MINUTES=15
